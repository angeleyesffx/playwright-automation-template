# ============================================================
# Marvel App API
# Generate your personal access token at:
# https://marvelapp.com/oauth/devtoken
# ============================================================
MARVEL_TOKEN=your_personal_access_token_here

# ============================================================
# UI Authentication (used by tests/auth/auth.setup.ts)
# Set these to enable authenticated UI tests.
# Leave blank to run UI tests without authentication.
# ============================================================
APP_BASE_URL=https://your-app.com
APP_EMAIL=your@email.com
APP_PASSWORD=yourpassword
