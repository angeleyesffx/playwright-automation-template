{
  "name": "playwright-automation-template",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "test": "npx playwright test --project='chromium' --headed",
    "test:ui": "npx playwright test tests/UI --headed",
    "test:api": "npx playwright test tests/api",
    "test:smoke:ui": "npx playwright test tests/UI --grep='@smoke' --headed",
    "test:smoke:api": "npx playwright test tests/api --grep='@smoke'",
    "test:smoke": "npx playwright test --grep='@smoke' --headed",
    "test:unit": "npx playwright test --project=unit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Playwright automation template with Marvel API and Google Search examples",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@faker-js/faker": "^9.9.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.0.10",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "uuid": "^9.0.0"
  }
}
